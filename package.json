{
  "name": "fecho",
  "version": "0.1.0",
  "description": "echo — a business-scenario coverage measurement engine for HTTP traffic (Nario-inspired)",
  "type": "module",
  "license": "MIT",
  "author": "Phillip Cheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phillipcheng/fecho.git"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
